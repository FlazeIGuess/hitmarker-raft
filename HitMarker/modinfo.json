{
  "name": "HitMarker",
  "author": "Flaze",
  "description": "Displays a visual hitmarker in the center of your screen whenever you successfully damage an enemy. The hitmarker appears for 0.5 seconds with smooth fade-in and fade-out animations. Works with all weapons including arrows, spears, and melee attacks.",
  "version": "1.3.0",
  "license": "GNU AGPLv3",
  "icon": "icon.png",
  "banner": "banner.png",
  "gameVersion": "1.0",
  "requiredByAllPlayers": false,
  "updateUrl": "https://www.raftmodding.com/api/v1/mods/hitmarker/version.txt",
  "isModPermanent": false,
  "excludedFiles": [],
  "requiredMods": [
    {
      "name": "RuntimeSettingsAPI",
      "version": "1.0.0",
      "optional": true
    }
  ],
  "modSettings": [
    {
      "type": "section",
      "name": "appearanceSection",
      "text": "Appearance Settings"
    },
    {
      "type": "slider",
      "name": "hitmarkerSize",
      "text": "Hitmarker Size",
      "access": "both",
      "default": 50,
      "range": {
        "min": 20,
        "max": 150,
        "decimals": 0
      },
      "section": "appearanceSection"
    },
    {
      "type": "slider",
      "name": "hitmarkerColorR",
      "text": "Color: Red",
      "access": "both",
      "default": 1.0,
      "range": {
        "min": 0.0,
        "max": 1.0,
        "decimals": 2
      },
      "section": "appearanceSection",
      "tooltip": "Red color component (0.0 - 1.0)"
    },
    {
      "type": "slider",
      "name": "hitmarkerColorG",
      "text": "Color: Green",
      "access": "both",
      "default": 1.0,
      "range": {
        "min": 0.0,
        "max": 1.0,
        "decimals": 2
      },
      "section": "appearanceSection",
      "tooltip": "Green color component (0.0 - 1.0)"
    },
    {
      "type": "slider",
      "name": "hitmarkerColorB",
      "text": "Color: Blue",
      "access": "both",
      "default": 1.0,
      "range": {
        "min": 0.0,
        "max": 1.0,
        "decimals": 2
      },
      "section": "appearanceSection",
      "tooltip": "Blue color component (0.0 - 1.0)"
    },
    {
      "type": "section",
      "name": "timingSection",
      "text": "Timing Settings"
    },
    {
      "type": "slider",
      "name": "displayDuration",
      "text": "Display Duration (seconds)",
      "access": "both",
      "default": 0.5,
      "range": {
        "min": 0.1,
        "max": 2.0,
        "decimals": 1
      },
      "section": "timingSection"
    },
    {
      "type": "slider",
      "name": "fadeInDuration",
      "text": "Fade In Speed (seconds)",
      "access": "both",
      "default": 0.1,
      "range": {
        "min": 0.0,
        "max": 0.5,
        "decimals": 1
      },
      "section": "timingSection"
    },
    {
      "type": "slider",
      "name": "fadeOutDuration",
      "text": "Fade Out Speed (seconds)",
      "access": "both",
      "default": 0.15,
      "range": {
        "min": 0.0,
        "max": 0.5,
        "decimals": 1
      },
      "section": "timingSection"
    },
    {
      "type": "section",
      "name": "comboSection",
      "text": "Combo Counter Settings"
    },
    {
      "type": "text",
      "text": "Note: If ComboCounter mod is installed, these settings are ignored and the standalone mod is used instead.",
      "section": "comboSection"
    },
    {
      "type": "checkbox",
      "name": "showComboCounter",
      "text": "Show Combo Counter",
      "access": "both",
      "default": true,
      "section": "comboSection",
      "tooltip": "Display combo counter when landing consecutive hits"
    },
    {
      "type": "slider",
      "name": "comboResetTime",
      "text": "Combo Reset Time (seconds)",
      "access": "both",
      "default": 5,
      "range": {
        "min": 1,
        "max": 10,
        "decimals": 0
      },
      "section": "comboSection",
      "tooltip": "Time before combo resets after last hit"
    },
    {
      "type": "section",
      "name": "customImageSection",
      "text": "Custom Image Settings"
    },
    {
      "type": "input",
      "name": "customImagePath",
      "text": "Custom Hitmarker Image Path",
      "access": "both",
      "default": "",
      "max": 500,
      "mode": "Standard",
      "section": "customImageSection",
      "tooltip": "Enter the full path to a PNG file (e.g., C:\\Users\\YourName\\Pictures\\hitmarker.png). Leave empty to use default hitmarker."
    },
    {
      "type": "button",
      "name": "loadCustomImage",
      "text": "Load Custom Image",
      "section": "customImageSection",
      "tooltip": "Click to load the image from the path above"
    },
    {
      "type": "button",
      "name": "resetToDefault",
      "text": "Reset to Default Image",
      "section": "customImageSection",
      "tooltip": "Click to restore the default hitmarker image"
    }
  ]
}