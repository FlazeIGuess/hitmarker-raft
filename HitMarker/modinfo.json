{
  "name": "HitMarker",
  "author": "Flaze",
  "description": "Displays a visual hitmarker in the center of your screen whenever you successfully damage an enemy. The hitmarker appears for 0.5 seconds with smooth fade-in and fade-out animations. Works with all weapons including arrows, spears, and melee attacks.",
  "version": "1.0.3",
  "license": "GNU AGPLv3",
  "icon": "icon.png",
  "banner": "banner.png",
  "gameVersion": "1.0",
  "requiredByAllPlayers": false,
  "updateUrl": "",
  "isModPermanent": false,
  "excludedFiles": [],
  "modSettings": [
    {
      "type": "slider",
      "name": "hitmarkerSize",
      "text": "Hitmarker Size",
      "access": "both",
      "default": 50,
      "range": {
        "type": "int",
        "min": 20,
        "max": 150,
        "decimals": 0
      }
    },
    {
      "type": "slider",
      "name": "displayDuration",
      "text": "Display Duration",
      "access": "both",
      "default": 0.5,
      "range": {
        "type": "time",
        "min": 0.1,
        "max": 2.0,
        "decimals": 1
      }
    },
    {
      "type": "slider",
      "name": "fadeInDuration",
      "text": "Fade In Speed",
      "access": "both",
      "default": 0.1,
      "range": {
        "type": "time",
        "min": 0.0,
        "max": 0.5,
        "decimals": 2
      }
    },
    {
      "type": "slider",
      "name": "fadeOutDuration",
      "text": "Fade Out Speed",
      "access": "both",
      "default": 0.15,
      "range": {
        "type": "time",
        "min": 0.0,
        "max": 0.5,
        "decimals": 2
      }
    }
  ]
}